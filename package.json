{
  "name": "fullstack-typescript-template",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm lint && pnpm tsconfig:check && pnpm typecheck && pnpm format:check && pnpm env:check && pnpm design:lint",
    "clean": "node scripts/clean.mjs",
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @repo/api dev",
    "dev:desktop": "pnpm --filter @repo/desktop dev",
    "dev:mfe": "turbo run dev --filter @repo/mfe-host --filter @repo/mfe-dashboard",
    "dev:mfe-dashboard": "pnpm --filter @repo/mfe-dashboard dev",
    "dev:mfe-host": "pnpm --filter @repo/mfe-host dev",
    "dev:mobile": "pnpm --filter @repo/mobile dev",
    "dev:proxy": "portless proxy start --https",
    "dev:proxy:stop": "portless proxy stop",
    "dev:proxy:unprivileged": "portless proxy start --port 1355 --https",
    "dev:trust": "portless trust",
    "dev:web": "pnpm --filter @repo/web dev",
    "db:generate": "pnpm --filter @repo/db db:generate",
    "db:migrate": "pnpm --filter @repo/db db:migrate",
    "db:seed": "pnpm --filter @repo/db db:seed",
    "db:studio": "pnpm --filter @repo/db db:studio",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d postgres",
    "dev:db:logs": "docker compose -f docker-compose.dev.yml logs -f postgres",
    "dev:db:stop": "docker compose -f docker-compose.dev.yml stop postgres",
    "dev:db:reset": "docker compose -f docker-compose.dev.yml down -v",
    "env:check": "pnpm --filter @repo/env check:examples",
    "format": "pnpm format:biome && pnpm format:prettier",
    "format:biome": "biome format --write .",
    "format:check": "biome format . && prettier --check .",
    "format:prettier": "prettier --write .",
    "licenses:check": "license-checker-rseidelsohn --production --excludePrivatePackages --onlyAllow=\"MIT;ISC;Apache-2.0;BSD-2-Clause;BSD-3-Clause;CC0-1.0;CC-BY-3.0;CC-BY-4.0;0BSD;Unlicense;MIT-0;Python-2.0;BlueOak-1.0.0;Apache 2.0;WTFPL;UPL-1.0;Artistic-2.0\" --summary",
    "lint": "biome lint --error-on-warnings .",
    "lint:fix": "biome lint --write .",
    "syncpack:check": "syncpack lint",
    "syncpack:fix": "syncpack fix-mismatches && syncpack format",
    "template:auth": "node scripts/select-auth-strategy.mjs",
    "template:rename": "node scripts/rename-template.mjs",
    "template:surfaces": "node scripts/select-surfaces.mjs",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "pnpm --filter @repo/web test:e2e",
    "test:watch": "vitest",
    "tsconfig:check": "node scripts/check-tsconfig-references.mjs",
    "typecheck": "turbo run typecheck",
    "design:lint": "design.md lint DESIGN.md",
    "bootstrap": "node scripts/bootstrap.mjs",
    "doctor": "node scripts/preflight.mjs",
    "test:scripts": "node --test scripts/*.test.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@google/design.md": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "license-checker-rseidelsohn": "catalog:",
    "prettier": "catalog:",
    "syncpack": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "portless": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "multer": ">=2.1.1",
      "path-to-regexp": ">=8.4.0",
      "@tootallnate/once": ">=3.0.1",
      "esbuild": ">=0.25.0",
      "postcss": ">=8.5.10",
      "uuid": ">=14.0.0"
    }
  }
}
