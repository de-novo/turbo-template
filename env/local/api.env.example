APP_ENV=local
NODE_ENV=development
PORT=4000
PROJECT_NAME=Fullstack TypeScript Template
PROJECT_SLUG=fullstack-typescript-template
PROJECT_TIMEZONE=Asia/Seoul
LOG_LEVEL=debug
AUTH_MODE=better-auth-embedded
AUTH_TOPOLOGY=modular-monolith
AUTH_AUDIENCE=repo-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_VERSION=0.0.0
# AUTH_ISSUER_URL=http://localhost:3000
# AUTH_SERVICE_URL=http://localhost:4001
# Connect to the local docker-compose Postgres (`pnpm dev:db`). Without this
# value, Better Auth falls back to its in-process memory adapter and sessions
# are lost on restart.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/fullstack_template
BETTER_AUTH_URL=http://localhost:4000
BETTER_AUTH_SECRET=local-only-change-me-change-me-32
# Enable @nestjs/schedule with the sample heartbeat job. In multi-replica
# deployments, run the scheduler in exactly one replica (separate workload, or
# a leader-election lock) — @nestjs/schedule does not coordinate across pods.
# JOBS_ENABLED=true
