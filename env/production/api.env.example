APP_ENV=production
NODE_ENV=production
PORT=4000
PROJECT_NAME=Fullstack TypeScript Template
PROJECT_SLUG=fullstack-typescript-template
PROJECT_TIMEZONE=Asia/Seoul
AUTH_MODE=better-auth-embedded
AUTH_TOPOLOGY=modular-monolith
AUTH_AUDIENCE=repo-api
WEB_ORIGIN=https://app.example.com
# AUTH_ISSUER_URL=https://auth.example.com
# AUTH_SERVICE_URL=https://auth.example.com
DATABASE_URL=postgres://app:change-me@db.example.com:5432/app
BETTER_AUTH_URL=https://app.example.com
BETTER_AUTH_SECRET=replace-with-a-production-secret-32
# Social SSO (optional — each provider activates only when both pair values are set)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# OpenTelemetry — set OTEL_EXPORTER_OTLP_ENDPOINT to your collector.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.internal:4318
# OTEL_SERVICE_NAME=fullstack-typescript-template-api
# OTEL_RESOURCE_ATTRIBUTES=deploy.env=production,service.namespace=app
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1
