APP_ENV=production
NODE_ENV=production
PORT=4000
PROJECT_NAME=Fullstack TypeScript Template
PROJECT_SLUG=fullstack-typescript-template
PROJECT_TIMEZONE=Asia/Seoul
LOG_LEVEL=info
AUTH_MODE=better-auth-embedded
AUTH_TOPOLOGY=modular-monolith
AUTH_AUDIENCE=repo-api
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com
# OTEL_SERVICE_VERSION=0.0.0
# AUTH_ISSUER_URL=https://auth.example.com
# AUTH_SERVICE_URL=https://auth.example.com
DATABASE_URL=postgres://app:change-me@db.example.com:5432/app
BETTER_AUTH_URL=https://app.example.com
BETTER_AUTH_SECRET=replace-with-a-production-secret-32
# JOBS_ENABLED=false: production replicas do not run the in-process scheduler by
# default. Run @nestjs/schedule from exactly one replica (a separate workload, a
# Kubernetes CronJob, or a leader-election lock) so cron tasks aren't multiplied
# by the replica count.
JOBS_ENABLED=false
