# Hoist coverage providers so per-package `vitest run --coverage` finds them via Node
# module resolution without each package having to declare the dep explicitly.
public-hoist-pattern[]=@vitest/coverage-*
# Avoid the interactive TTY prompt when pnpm decides to purge node_modules during
# install (e.g. after a public-hoist-pattern change).
confirmModulesPurge=false
