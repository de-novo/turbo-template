{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fullstack TypeScript Template",
  "version": "0.0.0",
  "identifier": "dev.template.fullstack",
  "build": {
    "beforeDevCommand": "pnpm dev:app -- --port 3001",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:3001",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fullstack TypeScript Template",
        "width": 1200,
        "height": 800
      }
    ]
  }
}
