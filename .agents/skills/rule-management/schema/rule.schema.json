{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-rule.schema.json",
  "title": "Agent Rule Frontmatter",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "summary",
    "status",
    "priority",
    "severity",
    "scope",
    "requires",
    "owner",
    "lastReviewed"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+(\\.[a-z0-9-]+)+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["draft", "active", "deprecated", "removed"]
    },
    "priority": {
      "type": "integer",
      "minimum": 0
    },
    "severity": {
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "scope": {
      "type": "object",
      "required": ["match"],
      "properties": {
        "match": {
          "type": "object",
          "required": ["any"],
          "properties": {
            "any": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "minProperties": 1,
                "maxProperties": 1,
                "additionalProperties": {
                  "type": ["string", "boolean"]
                }
              }
            }
          },
          "additionalProperties": false
        },
        "exclude": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "requires": {
      "type": "array",
      "items": { "type": "string" }
    },
    "conflictsWith": {
      "type": "array",
      "items": { "type": "string" }
    },
    "supersedes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "lastReviewed": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  },
  "additionalProperties": true
}
